<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Product Catalog</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('partials/header') %>

  <div class="container py-4">
    <div class="mb-4">
      <input id="searchInput" type="search" class="form-control" placeholder="Search products by name or description" />
    </div>

    <div id="productList" class="row gy-4">
      <% products.forEach((product) => { %>
        <div class="col-md-6 product-card">
          <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><a href="/products/<%= product.id %>"><%= product.name %></a></h5>

              <% if (product.discountPercentage) { %>
                <span class="badge bg-success mb-2"><%= product.discountPercentage %>% off</span>
              <% } else { %>
                <span class="badge bg-secondary mb-2">No discount</span>
              <% } %>

              <p class="card-text"><%- product.description %></p>
              <p class="mb-1">Price: $<%= product.price.toFixed(2) %></p>

              <% if (product.stock === 0) { %>
                <p><span class="badge bg-danger">Out of stock</span></p>
              <% } else if (product.stock <= 5) { %>
                <p><span class="badge bg-warning text-dark">Low stock</span></p>
              <% } else { %>
                <p><span class="badge bg-success">In stock</span></p>
              <% } %>

              <div class="mt-auto">
                <a href="/products/<%= product.id %>" class="btn btn-primary btn-sm">View details</a>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>
