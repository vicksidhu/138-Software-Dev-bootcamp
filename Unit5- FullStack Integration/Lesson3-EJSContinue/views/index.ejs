<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Recipes</title>
  <!-- Include Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>
  
  <div class="container mt-4">
    <h1>Recipe List</h1>

    <div class="mb-3">
      <input
        id="searchInput"
        type="search"
        class="form-control"
        placeholder="Search recipes by name, description, or ingredient"
        aria-label="Recipe search"
      />
    </div>

    <p id="noResults" class="text-warning d-none">No recipes match your search.</p>

    <div class="row">
      <%# Loop through recipes and render a Bootstrap card for each item. %>
      <% recipes.forEach(recipe => { %>
        <div class="col-md-4 mb-4 recipe-card">
          <div class="card h-100">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title">
                <a href="/recipe/<%= recipe.name %>"><%= recipe.name %></a>
              </h5>

              <!-- Conditional rendering: badges are shown based on recipe data. -->
              <% if (recipe.discountPercentage) { %>
                <span class="badge bg-success mb-2"><%= recipe.discountPercentage %>% off</span>
              <% } else { %>
                <span class="badge bg-secondary mb-2">No discount</span>
              <% } %>

              <p class="card-text mb-1">Ingredients: <strong><%= recipe.ingredients.length %></strong></p>
              <p class="card-text mb-3">Price: $<%= recipe.price.toFixed(2) %></p>

              <% if (recipe.stock === 0) { %>
                <p class="mb-3"><span class="badge bg-danger">Out of stock</span></p>
              <% } else if (recipe.stock <= 5) { %>
                <p class="mb-3"><span class="badge badge-low-stock">Low stock</span></p>
              <% } else { %>
                <p class="mb-3"><span class="badge badge-in-stock">In stock</span></p>
              <% } %>

              <ul class="list-group list-group-flush mb-3">
                <% recipe.ingredients.forEach(ingredient => { %>
                  <li class="list-group-item"><%= ingredient %></li>
                <% }) %>
              </ul>

              <div class="mt-auto">
                <p class="mb-1">Stock: <span class="fw-bold <%= recipe.stock === 0 ? 'text-danger' : 'text-success' %>"><%= recipe.stock %></span></p>
                <a href="/recipe/<%= recipe.name %>" class="btn btn-primary btn-sm">View details</a>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>
